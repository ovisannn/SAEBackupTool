<Window x:Class="SkyrimAEBackup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Skyrim AE Backup Tool" Height="540" Width="740"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Skyrim SE/AE Content Backup Tool"
                       FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="Backs up Creation Club / Anniversary Edition content and restores it."
                       Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Skyrim Folder:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="SkyrimPathBox" IsReadOnly="True"
                     Padding="5,3" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="Browse..." Margin="8,0,0,0"
                    Padding="12,4" Click="BrowseSkyrim_Click"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Backup Folder:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="BackupFolderBox" IsReadOnly="True"
                     Padding="5,3" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="Browse..." Margin="8,0,0,0"
                    Padding="12,4" Click="BrowseBackup_Click"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5,0,10">
            <Button Content="Backup AE Content" Padding="14,6" Margin="0,0,8,0"
                    Click="Backup_Click" x:Name="BackupBtn"/>
            <Button Content="Restore from Backup..." Padding="14,6" Margin="0,0,8,0"
                    Click="Restore_Click" x:Name="RestoreBtn"/>
            <Button Content="Scan AE Content" Padding="14,6"
                    Click="Scan_Click" x:Name="ScanBtn"/>
        </StackPanel>

        <Border Grid.Row="4" BorderBrush="#CCCCCC" BorderThickness="1"
                Background="#FAFAFA" Margin="0,5,0,5">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="LogBox" IsReadOnly="True" BorderThickness="0"
                         Background="Transparent"
                         TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"
                         Padding="6"/>
            </ScrollViewer>
        </Border>

        <StatusBar Grid.Row="5">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
