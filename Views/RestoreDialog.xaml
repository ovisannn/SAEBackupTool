<Window x:Class="SkyrimAEBackup.RestoreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restore AE Content" Height="600" Width="640"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="15" FontWeight="Bold"
                   Text="Select files to restore"/>
        <TextBlock Grid.Row="0" x:Name="ZipPathText" FontSize="10"
                   Foreground="Gray" Margin="0,22,0,0" TextTrimming="CharacterEllipsis"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,6">
            <Button Content="Select All" Padding="10,3" Margin="0,0,6,0"
                    Click="SelectAll_Click"/>
            <Button Content="Select None" Padding="10,3" Margin="0,0,6,0"
                    Click="SelectNone_Click"/>
            <TextBlock x:Name="CountText" VerticalAlignment="Center"
                       Margin="10,0,0,0" Foreground="Gray"/>
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1">
            <ListBox x:Name="FileList" SelectionMode="Extended"
                     BorderThickness="0" Padding="4">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  Content="{Binding Name}"
                                  Checked="ItemCheck_Changed"
                                  Unchecked="ItemCheck_Changed"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" x:Name="Progress" Height="18" Minimum="0" Maximum="100"/>
            <TextBlock Grid.Column="1" x:Name="ProgressText" Margin="10,0,0,0"
                       VerticalAlignment="Center" Text="0 / 0"/>
        </Grid>

        <TextBlock Grid.Row="4" x:Name="StatusText" Foreground="Gray" FontSize="11"
                   Margin="0,0,0,6" Text="Ready"/>

        <Border Grid.Row="5" BorderBrush="#CCCCCC" BorderThickness="1"
                Background="#FAFAFA">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="LogBox" IsReadOnly="True" BorderThickness="0"
                         Background="Transparent" TextWrapping="Wrap"
                         FontFamily="Consolas" FontSize="11" Padding="6"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel" Padding="14,5" Margin="0,0,8,0"
                    Click="Cancel_Click" x:Name="CancelBtn" IsCancel="True"/>
            <Button Content="Restore" Padding="18,5"
                    Click="Restore_Click" x:Name="RestoreBtn" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
